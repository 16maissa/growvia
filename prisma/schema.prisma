// Prisma schema for Insta Analyzer

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String?
  name              String?
  createdAt         DateTime  @default(now())
  analyses          Analysis[]
  imageGenerations  ImageGeneration[]
  videoProjects     VideoProject[]
  uploadedDocuments UploadedDocument[]
  chatMessages      ChatMessage[]

  userProfile       UserProfile?
  audits            Audit[]
  automationPrefs   AutomationPrefs?
  agentTasks        AgentTask[]
  generatedContents GeneratedContent[]
  userGoals         UserGoal[]
  courses           Course[]
  agentMemories     AgentMemory[]
}

model Analysis {
  id                 String   @id @default(cuid())
  instagramUsername  String
  sentimentGlobal    String
  frustrations       Json
  besoinsClients     Json
  opportunitesBusiness Json
  createdAt          DateTime @default(now())
  userId             String?
  user               User?    @relation(fields: [userId], references: [id])
}

model ImageGeneration {
  id         String   @id @default(cuid())
  prompt     String
  imageBase64 String
  createdAt  DateTime @default(now())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
}

model UploadedDocument {
  id        String   @id @default(cuid())
  fileName  String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model ChatMessage {
  id        String   @id @default(cuid())
  question  String
  answer    String
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
}

enum ProjectStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model VideoProject {
  id        String        @id @default(cuid())
  chatInput String
  videoUrl  String?
  status    ProjectStatus @default(PENDING)
  error     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  userId    String?
  user      User?         @relation(fields: [userId], references: [id])
  scenes    Scene[]
}

model Scene {
  id           String        @id @default(cuid())
  sceneNumber  Int
  imageUrl     String?
  audioUrl     String?
  videoUrl     String?
  promptText   String?       // Text prompt generated by LLM for the image
  audioText    String?       // Text generated by LLM for TTS
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  projectId    String
  project      VideoProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum PlanType {
  libre
  croissance
  autopilote
}

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  instagram_handle  String?
  niche             String?
  main_offer        String?
  price_range       String?
  target_audience   String?
  main_goal         String?
  plan              PlanType @default(libre)
  setup_done        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Audit {
  id                      String       @id @default(cuid())
  userId                  String
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  score                   Float?
  plan_type               String?
  errors_json             Json?
  metrics_json            Json?
  audience_json           Json?
  profile_json            Json?
  revenue_estimation_json Json?
  ai_report_json          Json?
  createdAt               DateTime     @default(now())
  actionPlans             ActionPlan[]
}

model ActionPlan {
  id           String      @id @default(cuid())
  auditId      String
  audit        Audit       @relation(fields: [auditId], references: [id], onDelete: Cascade)
  week_number  Int
  day_of_week  String
  content_type String
  topic        String
  cta          String?
  optimal_hour String?
  status       String      @default("pending")
  createdAt    DateTime    @default(now())
  agentTasks   AgentTask[]
}

enum AutoMode {
  libre
  semi_auto @map("semi-auto")
  auto
}

model AutomationPrefs {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  generate_reels        Boolean  @default(false)
  generate_images       Boolean  @default(false)
  generate_quizzes      Boolean  @default(false)
  auto_publish          Boolean  @default(false)
  auto_reply_comments   Boolean  @default(false)
  auto_reply_dms        Boolean  @default(false)
  validation_mode       String   @default("manual") // manual/auto
  mode                  AutoMode @default(libre)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum TaskStatus {
  planned
  pending
  running
  done
  failed
  skipped
}

model AgentTask {
  id                 String             @id @default(cuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  actionPlanId       String?
  actionPlan         ActionPlan?        @relation(fields: [actionPlanId], references: [id], onDelete: SetNull)
  task_type          String
  scheduled_at       DateTime?
  executed_at        DateTime?
  params_json        Json?
  result_json        Json?
  status             TaskStatus         @default(pending)
  retry_count        Int                @default(0)
  approved_at        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  generatedContents  GeneratedContent[]
}

model GeneratedContent {
  id                 String     @id @default(cuid())
  userId             String
  user               User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentTaskId        String?
  agentTask          AgentTask? @relation(fields: [agentTaskId], references: [id], onDelete: SetNull)
  type               String
  content_json       Json?
  preview_url        String?
  approved_at        DateTime?
  published_at       DateTime?
  instagram_post_id  String?
  status             String     @default("draft") // draft, approved, published, skipped
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
}

model UserGoal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal_id   String // visibility/formation/conversion/analysis
  weight    Float    @default(1.0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Course Feature Models ────────────────────────────────────────────────

model Course {
  id                  String             @id @default(cuid())
  userId              String
  user                User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  description         String?
  pinecone_index_id   String?
  telegram_bot_token  String?
  telegram_chat_id    String?
  telegram_bot_active Boolean            @default(false)
  createdAt           DateTime           @default(now())
  documents           CourseDocument[]
  interactions        TelegramInteraction[]
}

model CourseDocument {
  id                String   @id @default(cuid())
  courseId          String
  course            Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  filename          String
  pinecone_namespace String?
  indexed_at        DateTime?
  status            String   @default("pending") // pending / indexing / indexed / failed
  createdAt         DateTime @default(now())
}

model TelegramInteraction {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  chat_id      String?
  student_name String?
  question     String
  answer       String?
  answered_at  DateTime?
  createdAt    DateTime @default(now())
}

model AgentMemory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  key       String
  value_json Json
  updatedAt DateTime @updatedAt

  @@unique([userId, key])
}
